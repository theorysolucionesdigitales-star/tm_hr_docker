# ============================================================
# .gitattributes — Control de Line Endings para Docker
# ============================================================
# Por defecto: Git normaliza los archivos de texto a LF en el
# repositorio, y los convierte a CRLF en checkout en Windows.
# Los archivos shell y de configuración de docker DEBEN
# mantenerse en LF siempre que se clonen en Linux/VPS.
# ============================================================

# Regla general: todos los archivos de texto usan LF en el repo
* text=auto eol=lf

# ── Archivos que SIEMPRE deben ser LF (críticos para Docker/Linux) ──────────

# Scripts de shell
*.sh        text eol=lf

# Dockerfiles y configuración de contenedores
Dockerfile  text eol=lf
*.conf      text eol=lf
Caddyfile   text eol=lf

# Docker Compose
docker-compose*.yml text eol=lf

# YAML en general
*.yml       text eol=lf
*.yaml      text eol=lf

# SQL migrations
*.sql       text eol=lf

# Variables de entorno
.env        text eol=lf
.env.*      text eol=lf

# ── Archivos de código (LF también, buena práctica cross-platform) ───────────
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.toml      text eol=lf

# ── Archivos binarios — Git no toca sus bytes ────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.lockb     binary
