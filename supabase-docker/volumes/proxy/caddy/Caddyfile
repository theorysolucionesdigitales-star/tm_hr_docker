# ── Sitio principal: Frontend React + API de Supabase ───────────────────────
tailormaderesearch.cl {

    # Rutas de la API de Supabase → Kong
    @supabase_api path /auth/v1/* /rest/v1/* /graphql/v1 /realtime/v1/* /storage/v1/* /functions/v1/* /mcp /sso/*

    handle @supabase_api {
        reverse_proxy kong:8000
    }

    # Todo lo demás → Frontend React (Nginx)
    handle {
        reverse_proxy frontend:80
    }

    header -server
}

# ── Supabase Studio en puerto alternativo (sin subdomain) ────────────────────
# Acceder en: https://tailormaderesearch.cl:8443
# Caddy reutiliza el certificado SSL del dominio principal.
# Requiere: sudo ufw allow 8443/tcp en el VPS
tailormaderesearch.cl:8443 {

    basic_auth {
        # PROXY_AUTH_PASSWORD is overwritten with the bcrypt hash on startup
        {$PROXY_AUTH_USERNAME} {$PROXY_AUTH_PASSWORD}
    }

    reverse_proxy studio:3000

    header -server
}
